# Wiki.js Configuration
WIKIJS_URL=http://localhost:3000
WIKIJS_API_TOKEN=your_api_token_here

# Alternative: Username/Password authentication
# WIKIJS_USERNAME=your_username
# WIKIJS_PASSWORD=your_password

# MCP Server Configuration
MCP_SERVER_NAME=wikijs-mcp
LOG_LEVEL=info

# Optional: Custom GraphQL endpoint path (default: /graphql)
# WIKIJS_GRAPHQL_PATH=/graphql